# Environment Variables - Example Configuration
# Copy this file to .env.local and update values for your environment

# ===== Frontend Configuration =====

# API Base URL
# For local development with Vite proxy: leave empty or use http://localhost:8000
# For Azure production: use https://fitness-tracker-api.azurewebsites.net
# For other environments: use the backend URL
VITE_API_URL=

# ===== Backend Configuration (see backend/.env.example) =====
# CORS_ORIGINS: Comma-separated list of allowed origins
